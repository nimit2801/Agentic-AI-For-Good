# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — needed for sync scripts and admin routes, never exposed to browser
# Get from: Supabase dashboard → Settings → API → service_role key (keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── OpenAI (optional — search falls back to keyword mode without it) ─────────
# Without this, /api/tools/search still works via PostgreSQL full-text search
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Site URL ──────────────────────────────────────────────────────────────────
# Used by the hosted MCP server to call back to /api/tools/search
# Local dev: http://localhost:3000  |  Production: https://agenticaiforgood.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Resend (optional — email features disabled without it) ───────────────────
# Powers welcome email, weekly digest, and tool spotlight emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── Cron protection (optional — only needed for Vercel cron endpoints) ────────
# Any random secret string. Set the same value in Vercel dashboard → Environment Variables
CRON_SECRET=your-random-secret-here
